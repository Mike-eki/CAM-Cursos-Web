---
import CardLink from "../components/CardLink.astro";
import CTAButton from "../components/CTAButton.astro";
import Icon from "../components/Icon.astro";
import TrustNumbers from "../components/TrustNumbers.astro";
import Wrapper from "../components/Wrapper.astro";
import CertificateIcon from "../icons/CertificateIcon.astro";
import HeartHearIcon from "../icons/HeartHearIcon.astro";
import programs from "../data/programs.json";

export interface Props {
    isModal?: boolean;
}

const { isModal = false } = Astro.props;
---

<Wrapper className="grid-wrapper">
    <header class="heading-icon h-grid-one">
        <HeartHearIcon />
        <h2>¡Acelera tu carrera de medicina!</h2>
    </header>

    <!-- <section class="trust-container"> -->
    <!-- <TrustNumbers num="600" title="Clases impartidas" />
        <TrustNumbers num="36" title="Medicos" />
        <TrustNumbers num="90" title="Simulacros" /> -->
    <!-- </section> -->

    <section class="companies description-one">
        <p>
            Creemos firmemente que el acompañamiento es clave para el éxito de
            tu carrera académica.
        </p>
    </section>

    <section class="grid card-one">
        {
            programs
                .filter((p) =>
                    [
                        "ingreso-medicina",
                        "acompanamiento-cursado",
                        "finales-medicina",
                        "capacitacion-medicina",
                    ].includes(p.courseId),
                )
                .map((program) => (
                    <CardLink
                        title={program.title}
                        path={program.path}
                        desc={program.desc}
                        aspectRatio="rect"
                        courseId={program.courseId}
                    >
                        <Icon icon={program.icon} width="30" slot="icon" />
                    </CardLink>
                ))
        }
    </section>

    <header class="heading-icon h-grid-two">
        <CertificateIcon />
        <h2>¡No pierdas tu progreso!</h2>
    </header>

    <section class="companies description-two">
        <div class="revalida-container">
            <!-- <h3 class="revalida-title">CURSO DE REVALIDA</h3> -->
            <!-- <ul class="revalida-phases">
                <li><strong>Fase 1:</strong> Etapa teórica</li>
                <li><strong>Fase 2:</strong> Etapa Práctica</li>
            </ul> -->
            <p>
                Ofrecemos cursos preparatorios para Revalidación que se adaptan
                a vos. Estudia a tu ritmo, domina el examen y alcanza tu meta
                con confianza.
            </p>
        </div>
    </section>

    <section class="grid card-two">
        {
            programs
                .filter((p) => p.courseId === "revalidacion-tramites")
                .map((program) => (
                    <CardLink
                        title={program.title}
                        path={program.path}
                        desc={program.desc}
                        className="rect"
                        aspectRatio="16/7.7"
                        courseId={program.courseId}
                    >
                        <Icon icon={program.icon} width="30" slot="icon" />
                    </CardLink>
                ))
        }
    </section>

    <footer class="button">
        <CTAButton
            text="Quiero acelerar mi carrera de medicina"
            waMessage="¡Hola! Les escribo desde su web porque quiero acelerar mi carrera de medicina en CAM."
        />
    </footer>
</Wrapper>

<style>
    .heading-icon {
        text-align: center;
    }

    .trust-container {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .companies {
        display: flex;
        flex-direction: column;
        text-align: center;
        align-items: center;
        gap: 0.5rem;
    }
    .companies small {
        font-weight: 600;
    }
    .logos {
        display: flex;
        justify-content: center;
        gap: 1.25rem;
    }

    .row {
        display: flex;
        gap: 0.75rem;
    }

    .grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0.75rem;
    }

    /* Rectangle cards span 2 columns by default */
    :global(.grid > .rect) {
        grid-column: span 2;
    }

    h2,
    p {
        margin: 0;
    }

    .revalida-container {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
        background-color: transparent;
        text-align: center;
        width: 100%;
        align-items: center;
    }

    .revalida-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--color-text-heading, #fcfcfc);
        margin: 0;
        text-transform: uppercase;
    }

    .revalida-phases {
        display: flex;
        flex-direction: row;
        justify-content: center;
        flex-wrap: wrap;
        gap: 1rem;
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .revalida-phases li {
        display: flex;
        align-items: center;
        justify-content: center;
        background-color: var(--color-surface-soft, #1e1e1e);
        padding: 0.75rem 1.5rem;
        border-radius: 0.5rem;
        gap: 0.5rem;
        border: 1px solid var(--color-border-light, rgba(255, 255, 255, 0.1));
        font-weight: 500;
        font-size: 1.125rem;
        color: var(--color-text-body, #edf0f4);
        list-style-type: none;
    }

    @media screen and (max-width: 400px) {
        .grid {
            grid-template-columns: 1fr;
        }
        /* On mobile, all cards take full width */
        :global(.grid > .rect) {
            grid-column: span 1;
        }
    }

    /* Tablet: cards fill 2 columns */
    @media screen and (min-width: 401px) and (max-width: 849px) {
        .grid {
            grid-template-columns: repeat(2, 1fr);
        }
        :global(.grid > .rect) {
            grid-column: span 2;
        }
    }

    @media screen and (min-width: 850px) {
        .grid {
            grid-template-columns: auto;
        }
        .mobile-wrapper {
            grid-template-columns: 1fr 1fr 1fr 1fr;
        }

        .h-grid-one {
            grid-column: 1/3;
            grid-row: 1;

            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;

            font-size: 1.5rem;
            font-weight: 500;
        }
        .h-grid-two {
            grid-column: 3/5;

            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;

            font-size: 1.5rem;
            font-weight: 500;
        }

        .trust-container {
            grid-column: 1/5;
            grid-row: 3;
        }
        .description-one {
            grid-column: 1/3;
            grid-row: 2;
        }
        .description-two {
            grid-column: 3/5;
        }
        .description-one p,
        .description-two p {
            max-width: 42ch;
            font-size: 1.5rem;
            margin-inline: auto;
        }
        .card-one {
            grid-column: 3/5;
            grid-row: 1/3;
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 1rem;
        }
        .card-two {
            grid-column: 1/3;
            grid-row: 3/5;
        }
        .last-card {
            grid-column: 3;
            grid-row: 1;
        }
        .button {
            grid-column: 2/4;
        }
    }
</style>
