---
import CTAButton from "../components/CTAButton.astro";
import TrustNumbers from "../components/TrustNumbers.astro";
import Wrapper from "../components/Wrapper.astro";
import HSBCIcon from "../icons/HSBCIcon.astro";
import LanguageIcon from "../icons/LanguageIcon.astro";

export interface Props {
    isModal?: boolean;
}

const { isModal = false } = Astro.props;
---

<Wrapper className="grid-wrapper">
    <header class="heading-icon h-grid-one">
        <LanguageIcon />
        <h2>¡Aprende un nuevo idioma!</h2>
    </header>

    <section class="trust-container">
        <!-- <TrustNumbers num="1000" title="Experiencias" />
        <TrustNumbers num="900" title="Clases" />
        <TrustNumbers num="15" title="Trayectoria" /> -->
    </section>

    <section class="companies description-one">
        <p>
            Con un enfoque cultural y totalmente personalizado, aprende a
            comunicarte de forma profesional y nativa con otra lengua.
        </p>
    </section>

    <section class="badges-container card-one">
        <div class="badge-square">Español como lengua extranjera</div>
        <div class="badge-square">Inglés</div>
        <div class="badge-square">Portugués</div>
        <div class="badge-square">Italiano</div>
        <div class="badge-square">Francés</div>
    </section>

    <footer class="button">
        <CTAButton
            text="Quiero aprender un nuevo idioma"
            waMessage="¡Hola! Les escribo desde su web porque quiero aprender un nuevo idioma en CAM."
        />
    </footer>
</Wrapper>

<style>
    .heading-icon {
        text-align: center;
    }

    .trust-container {
        display: flex;
        justify-content: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .companies {
        display: flex;
        flex-direction: column;
        text-align: center;
        align-items: center;
        gap: 0.5rem;
    }
    .companies small {
        font-weight: 600;
    }
    .logos {
        display: flex;
        justify-content: center;
        gap: 1.25rem;
    }

    .row {
        display: flex;
        gap: 0.75rem;
    }

    .badges-container {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem 1.5rem;
        justify-content: center;
        align-items: center;
        width: 100%;
        margin: 0 auto;
        padding-top: 1rem;
    }

    .badge-square {
        width: 135px;
        box-sizing: border-box;
        aspect-ratio: 1 / 1;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: linear-gradient(135deg, var(--color-surface-soft, #2a2a2a), var(--color-surface-dark, #1a1a1a));
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 0.75rem;
        font-weight: 600;
        font-size: min(1rem, 4vw);
        color: var(--color-text-body, #ffffff);
        transition: transform 0.2s, border-color 0.2s, box-shadow 0.2s;
        box-shadow: 0 4px 6px rgba(0,0,0,0.2);
    }

    .badge-square:hover {
        transform: translateY(-5px);
        border-color: rgba(255, 255, 255, 0.3);
        box-shadow: 0 8px 12px rgba(0,0,0,0.3);
    }

    h2,
    p {
        margin: 0;
    }

    @media screen and (max-width: 600px) {
        .badges-container {
            gap: 1.5rem 1rem;
        }
        .badge-square {
            width: calc(50% - 0.5rem);
            max-width: 140px;
            font-size: 0.95rem;
        }
    }

    @media screen and (max-width: 350px) {
        .badge-square {
            width: 100%;
            max-width: 200px;
        }
    }

    @media screen and (min-width: 850px) {

        .mobile-wrapper {
            grid-template-columns: 1fr 1fr 1fr 1fr;
        }

        .h-grid-one {
            grid-column: 1/5;
            grid-row: 1;

            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;

            font-size: 1.5rem;
            font-weight: 500;
        }

        .trust-container {
            grid-column: 1/5;
            grid-row: 2;
        }
        .description-one {
            grid-column: 1/5;
            grid-row: 3;
        }
        .description-one p {
            max-width: 42ch;
            font-size: 1.5rem;
            margin-inline: auto;
        }
        .card-one {
            grid-column: 1/5;
            grid-row: 4;
        }
        .button {
            grid-column: 2/4;
            grid-row: 5;
        }
    }
</style>
