---
import WhatsAppIcon from "../icons/WhatsAppIcon.astro"

const { text = "Button", waMessage = "" } = Astro.props
---

<a href=`https://wa.me/5493412166867?text=${encodeURIComponent(waMessage)}` target="_blank" rel="noopener noreferrer" class="whatsapp-btn" aria-label={`Contactar por WhatsApp para ${text}`}>
    <WhatsAppIcon />
    { text }
</a>

<style>
  .whatsapp-btn {
    width: -webkit-fill-available;
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    background-color: var(--color-button);        /* ej: var(--color-whatsapp) */
    color: var(--color-button-text);              /* ej: white */
    padding-inline: 0.75rem;
    padding-block: 0.5rem;
    border-radius: 1rem;
    text-wrap: pretty;
    
/* Glow base muy sutil */
    box-shadow: 
      0 0 8px 1px var(--color-whatsapp)40,
      0 0 14px 1px var(--color-whatsapp)20;
    
    /* Animación neón suave y discreta */
    animation: subtle-neon 5s ease-in-out infinite alternate;

    transition: 
      box-shadow 0.4s ease,
      scale 0.25s ease;
  }


@keyframes subtle-neon {
    from {

      box-shadow: 
        0 0 8px  1px var(--color-text-muted)30,
        0 0 14px 1px var(--color-text-muted)18,
        0 0 22px 0px var(--color-text-muted)0d;
    }
    to {
        box-shadow: 
        0 0 12px  3px #bbbbbb55,
        0 0 20px  2px var(--color-text-muted)35,
        0 0 30px  1px #88888818;
    }
  }

  /* Opcional: leve mejora al hover */
  .whatsapp-btn:hover,
  .whatsapp-btn:focus-visible {
    animation: subtle-neon-green 3.2s ease-in-out infinite alternate;
    /*animation-duration: 3.2s;    acelera un toque al interactuar */
    scale: 1.03;
    box-shadow: 
      0 0 14px  4px var(--color-whatsapp)70,
      0 0 24px  5px var(--color-whatsapp)40;
    transition: all 0.3s ease;
  }

  /* Para que el hover no "salte" si ya está animado */
  .whatsapp-btn {
    transition: scale 0.25s ease;
  }


  @keyframes subtle-neon-green {
    from {
      box-shadow: 
        0 0 10px  2px var(--color-whatsapp)50,
        0 0 18px  3px var(--color-whatsapp)30,
        0 0 28px  1px var(--color-whatsapp)15;
    }
    to {
      box-shadow: 
        0 0 16px  6px var(--color-whatsapp)80,
        0 0 28px  8px var(--color-whatsapp)50,
        0 0 40px  4px var(--color-whatsapp)25;
    }
  }
</style>