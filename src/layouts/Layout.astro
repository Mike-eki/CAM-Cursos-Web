---
import { Font } from "astro:assets";

const {
	title = "Instituto CAM | Cursos con rápida Salida Laboral, Idiomas y Apoyo para Medicina",
	description = "Más de 15 años transformando vidas. En Instituto CAM ofrecemos cursos con rápida salida laboral, idiomas (español, portugués, inglés, italiano) y apoyo universitario para medicina. Clases presenciales en Argentina y Paraguay, o virtuales desde cualquier lugar. ¡Tu futuro empieza acá!",
	image = "seo/og.png",
	canonicalURL = new URL(Astro.url.pathname, Astro.site),
	keywords = "cursos salida laboral, aprender idiomas, apoyo medicina argentina, apoyo medicina paraguay, instituto cam",
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const resolvePath = (path: string) => `${base}/${path.replace(/^\//, "")}`;
const resolveUrl = (path: string) => new URL(resolvePath(path), Astro.site);
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<Font cssVariable="--font-clash-display" />

		<!-- Canonical URL -->
		<link rel="canonical" href={canonicalURL} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={Astro.url} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolveUrl(image)} />
		<meta property="og:image:secure_url" content={resolveUrl(image)} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />

		<!-- X (Twitter) -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={Astro.url} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={resolveUrl(image)} />

		<!-- Favicon -->
		<link
			rel="apple-touch-icon"
			sizes="180x180"
			href={resolvePath("apple-touch-icon.png")}
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="32x32"
			href={resolvePath("favicon-32x32.png")}
		/>
		<link
			rel="icon"
			type="image/png"
			sizes="16x16"
			href={resolvePath("favicon-16x16.png")}
		/>
		<link rel="manifest" href={resolvePath("seo/site.webmanifest")} />
		<meta name="keywords" content={keywords} />

		<!-- Structured Data (JSON-LD) -->
		<script
			type="application/ld+json"
			is:inline
			set:html={JSON.stringify({
				"@context": "https://schema.org",
				"@type": "EducationalOrganization",
				name: "Instituto CAM",
				url: Astro.site?.toString(),
				logo: new URL(
					resolvePath("seo/logo-og.png"),
					Astro.site,
				).toString(),
				description:
					"Más de 15 años transformando vidas con cursos con rápida salida laboral, idiomas y apoyo para medicina.",
				address: {
					"@type": "PostalAddress",
					addressCountry: ["Argentina", "Paraguay"],
				},
			})}
		/>

		<!-- Meta Pixel Code -->
		<script is:inline>
			!(function (f, b, e, v, n, t, s) {
				if (f.fbq) return;
				n = f.fbq = function () {
					n.callMethod
						? n.callMethod.apply(n, arguments)
						: n.queue.push(arguments);
				};
				if (!f._fbq) f._fbq = n;
				n.push = n;
				n.loaded = !0;
				n.version = "2.0";
				n.queue = [];
				t = b.createElement(e);
				t.async = !0;
				t.src = v;
				s = b.getElementsByTagName(e)[0];
				s.parentNode.insertBefore(t, s);
			})(
				window,
				document,
				"script",
				"https://connect.facebook.net/en_US/fbevents.js",
			);
			fbq("init", "2026830631201738");
			fbq("track", "PageView");
		</script>
		<noscript>
			<img
				height="1"
				width="1"
				style="display:none"
				src="https://www.facebook.com/tr?id=2026830631201738&ev=PageView&noscript=1"
			/>
		</noscript>
		<!-- End Meta Pixel Code -->
	</head>
	<body>
		<slot />
	</body>
</html>

<style>
	:root {
		/* Colors - Brand */
		--color-primary: #0077ff;
		--color-primary-rgb: 0, 119, 255;
		--color-whatsapp: #25d366;
		--color-whatsapp-dark: #128c7e;
		--color-whatsapp-rgb: 37, 211, 102;

		/* Colors - Base */
		--color-black: #000000;
		--color-white: #ffffff;
		--color-white-rgb: 255, 255, 255;

		/* Text Colors */
		--color-text-body: #edf0f4;
		--color-text-bold: #f1f1f1;
		--color-text-heading: #fcfcfc;
		--color-text-muted: #aaaaaa;

		/* Surface & Backgrounds */
		--color-bg-main: #000000;
		--color-container-bg: #0f0f0f;
		--color-surface-dark: #141414;
		--color-surface-soft: #1e1e1e;
		--color-bg-wrapper: #f4f4f9;
		--color-bg-card: #ffffff;
		--color-bg-card-border: #dcdcdc;

		/* UI Elements */
		--color-icon: #eeeeee;
		--color-button: #fcfcfc;
		--color-button-text: #000;
		--color-button-hover: #111111;
		--color-button-text-hover: #f0f0f0;
		--color-border-light: rgba(var(--color-white-rgb), 0.1);

		/* Brand Logos & SVGs */
		--color-logo: #000;

		/* Accent / Special */
		--color-gold: #fcbf49;
		--color-brown: #843511;
		--color-red-accent: #ff4d59;

		/* Flag Colors (for reference or dynamic use) */
		--color-flag-ar-blue: #75aadb;
		--color-flag-ar-sun: #fcbf49;
		--color-flag-py-red: #d52b1e;
		--color-flag-py-blue: #0038a8;
		--color-flag-py-green: #007127;
		--color-flag-py-yellow: #ffac33;
		--color-flag-py-gray: #99aab5;
	}

	html,
	body {
		padding: 8px;
		margin: 0;

		background-color: var(--color-bg-main);

		font-family: var(--font-clash-display), sans-serif;
		color: var(--color-text-body);
	}
</style>
